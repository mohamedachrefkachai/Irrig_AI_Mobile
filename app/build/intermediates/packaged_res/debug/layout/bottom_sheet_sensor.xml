<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sensor"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvSensorType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Type: Moisture"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvSensorStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: OK"
        android:textSize="14sp"
        android:textColor="@color/primary_green"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvSensorValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Current: --"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="History (mock)"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvSensorHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Last 24h: 45%, 42%, 48%"
        android:textSize="14sp"
        android:textColor="@color/text_primary" />

</LinearLayout>
