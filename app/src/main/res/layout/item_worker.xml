<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvWorkerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jean Dupont"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvWorkerStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ON_DUTY"
                    android:textSize="14sp"
                    android:textColor="@color/primary_green"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvWorkerTask"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Task: Check Zone 1"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvWorkerRemark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remark: Returns Monday"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="end">

            <Button
                android:id="@+id/btnAssignTask"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assign Task"
                android:textSize="12sp"
                android:backgroundTint="@color/primary_green"
                android:textColor="@color/white"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnAddRemark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Remark"
                android:textSize="12sp"
                android:backgroundTint="@color/status_blue"
                android:textColor="@color/white"
                android:paddingHorizontal="12dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
